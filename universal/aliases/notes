# Aliases related to 'notes' git repository


# Changing directory aliases
alias cdnotes='cd /home/jake/notes; git pull'
alias cd12='cd /home/jake/notes/12; git pull'
alias cdbook='cd /home/jake/notes/Books; git pull'
alias cd1='cd /home/jake/notes/12/1_*; git pull'
alias cd2='cd /home/jake/notes/12/2*; git pull'
alias cd3='cd /home/jake/notes/12/3_*; git pull'
alias cd4='cd /home/jake/notes/12/4_*; git pull'

# File creation and editing aliases
alias nn='v "`date $DATE_FORMAT`.md"'
alias vtodo='v /home/jake/notes/todo.md'
alias vkeydates='v "/home/jake/notes/keydates.md"'

# Repo management aliases
alias cn='pwd="`pwd`"; cd /home/jake/notes/; git add .; git commit -m "update `date "+%Y-%m-%d"`"; git push; cd "$pwd"' #Commit notes
