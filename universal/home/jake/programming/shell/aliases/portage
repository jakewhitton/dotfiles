# Aliases related to the Portage package manager for Gentoo

# Update ebuild heirarchy and package listings
alias esync='sudo emerge --sync'

# Update packages
alias eu='sudo emerge --ask --newuse --update --deep @world'

# Update ebuilds and then update packages
alias u='sudo emerge --sync; sudo emerge --ask --newuse --update --deep @world'

# Install a package
alias ei='sudo emerge --ask' # Emerge Install
