# Aliases related to programming tasks

# Changing directory aliases
alias cdsandbox='cd /home/jake/Programming/sandbox/C++/'

# Compilation and execution aliases
alias compile='sudo g++ -o run.exe *.cpp --std=c++11'
alias compileopengl='sudo g++ -o run.exe main.cpp -lglfw -lGL -lm -lXrandr -lXi -lX11 -lXxf86vm -lpthread -lGLEW --std=c++14'
