#include "colorscheme"

URxvt*transparent:	true
URxvt*shading:		10

URxvt.background:	black
URxvt.foreground:	white

URxvt.scrollBar:	false

URxvt.font:		xft:InconsolataforPowerline Nerd Font:size=12
URxvt.boldFont:		xft:InconsolataforPowerline Nerd Font:size=12

URxvt.perl-ext-common: clipboard
URxvt.keysym.C-c:	perl:clipboard:copy
URxvt.keysym.C-v:	perl:clipboard:paste

Xft.autohint:		0
Xft.antialias:		1
Xft.hinting:		true
Xft.hintstyle:		full
Xft.dpi:		141
Xft.rgba:		rgb
Xft.lcdfilter:		lcddefault
