command=/usr/libexec/i3blocks/$BLOCK_NAME
separator_block_width=15
markup=pango

[ram]
command=printf "<span foreground=\"#ff0000\">""%sMB/%sGB[%s%%]""</span>" "$(free -m | grep "Mem:" | tr -s ' ' | cut -d ' ' -f 3)" "$(echo "scale=2;$( free -m | grep 'Mem:' | tr -s ' ' | cut -d ' ' -f 2 ) / 1000" | bc)" "$(echo "scale=1; $(free -m | grep "Mem:" | tr -s ' ' | cut -d ' ' -f 3) * 100 / $(free -m | grep 'Mem:' | tr -s ' ' | cut -d ' ' -f 2)" | bc | sed -r 's/^(-?)\./\10\./')"
interval=5

[disk]
command=printf "%s%s" `echo "scale=2;$(df -m | grep /dev/sda2 | tr -s ' ' | cut -d ' ' -f 4) / 1000" | bc` "GB"
interval=10

[battery]
command=acpi=$(acpi);acpi=${acpi#Battery 0: };printf "%s %sW\n" "$(printf "<span foreground='%s'>%s %s</span>" "$( [ $(echo "$acpi" | cut -d ' ' -f 1 | tr -d ',' ) == "Discharging" ] && echo -n "#FFFFFF" || echo -n "#00FF00" )" "$(echo "$acpi" | cut -d ' ' -f 2 | tr -d ',')" "$( [ "$(echo "$acpi" | cut -d ' ' -f 3)" == "" ] && echo -n "" || echo -n "$(echo "$acpi" | cut -d ' ' -f 3)" )")" "$(echo "scale=2;`cat /sys/class/power_supply/BAT0/power_now` / 1000000" | bc)"
interval=5

[volume]
command=pactllistsinks=$(pactl list sinks | grep -A 9 "Sink #0" | grep -A 1 "Mute:");volume=$(echo "$pactllistsinks" | grep "Volume:" | tr -s ' ' | cut -d ' ' -f 5 | tr -d '%');mute=$(echo "$pactllistsinks" | grep "Mute:" | tr -s ' ' | cut -d ' ' -f 2); printf "%s [%s%%]" "$( [ "$mute" == "yes" ] && echo "Muted" || echo "$( [ $volume -le 0 ] && echo -n "" || echo -n "$( [ $volume -lt 50 ] && echo -n "" || echo -n "")" )")" "$volume"
interval=5

[date]
command=date "+ %a %-d/%-m/%Y"
interval=1

[time]
command=date "+ %-I:%M:%S%p"
interval=1
